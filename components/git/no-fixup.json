{
  "name": "git/no-fixup",
  "description": "Validate no fixup! or squash! commits exist on current branch",
  "nodes": {
    "check": { "type": "command", "description": "no fixup commits", "run": "! git log --oneline origin/master..HEAD | grep -qE '^(fixup|squash)!'" },
    "list": { "type": "command", "description": "list fixup commits", "run": "git log --oneline origin/master..HEAD | grep -E '^(fixup|squash)!' || true" }
  }
}
